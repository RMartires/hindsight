# ============================================================
# These are the SAME env vars used by the TradingAgents repo.
# You can symlink or copy your TradingAgents/.env here.
# ============================================================

# LLM Providers (set the one you use)
# For OpenRouter models (e.g. openai/gpt-4o:free), set LLM_PROVIDER=openrouter and OPENROUTER_API_KEY.
LLM_PROVIDER=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Data providers
ALPHA_VANTAGE_API_KEY=

# Optional: override LLM models (defaults come from TradingAgents/default_config.py)
# LLM_PROVIDER=openrouter
# QUICK_THINK_LLM=openrouter/free
# DEEP_THINK_LLM=openrouter/free

# LLM HTTP client (OpenAI-compatible providers only)
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT=120

# SSE: max idle time (seconds) between events on /api/stream before "Stream timeout" (default 1800)
# STREAM_IDLE_TIMEOUT_SEC=1800

# Cap LLM completions per rolling 60 seconds
# LLM_RATE_LIMIT_RPM=30

# Optional: rough USD estimate in the UI (per 1M tokens). Omit or set 0 to hide $ estimate.
LLM_PRICE_INPUT_PER_1M_TOKENS=0.065
LLM_PRICE_OUTPUT_PER_1M_TOKENS=0.26

# Kite Connect (Zerodha) — optional
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=

# Supabase — optional (completed-run cache for UI replay; use service role key on server only)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Browser CORS: comma-separated origins when the UI is not on localhost (e.g. Vercel + custom domain).
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.example.com

# Langfuse observability — optional
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROJECT_ID=your-project-id
