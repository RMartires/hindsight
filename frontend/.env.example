# Public API origin (no trailing slash). Used for:
# - Browser SSE to /api/stream (low-latency; avoids Next proxy buffering)
# - next.config rewrites: /api/* → this host (local default http://localhost:8000 when unset)
#
# Production / Vercel: set to your API, e.g. https://api.example.com
# NEXT_PUBLIC_BACKEND_URL=https://api.example.com
